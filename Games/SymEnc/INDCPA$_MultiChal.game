// Joy of Cryptography Chapter 7 calls this "CPA$ security".

import '../../Primitives/SymEnc.primitive';

Game Real(SymEnc E) {
    E.Key k;
    Void Initialize() {
        k = E.KeyGen();
    }
    E.Ciphertext CTXT(E.Message m) {
        return E.Enc(k, m);
    }
}

Game Random(SymEnc E) {
    E.Key k;
    Void Initialize() {
        k = E.KeyGen();
    }
    E.Ciphertext CTXT(E.Message m) {
        E.Ciphertext c <- E.Ciphertext;
        return c;
    }
}

export as INDCPA$_MultiChal;
