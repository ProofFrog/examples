Game Replacement(Int lambda) {
    BitString<lambda> Samp() {
        BitString<lambda> r <- BitString<lambda>;
        return r;
    }
}

Game NoReplacement(Int lambda) {
    Set<BitString<lambda>> R;

    BitString<lambda> Samp() {
        BitString<lambda> r <-uniq[R] BitString<lambda>;
        return r;
    }
}

export as Sample;
