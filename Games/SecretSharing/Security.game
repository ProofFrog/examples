import '../../Primitives/SecretSharing.primitive';

Game Left(SecretSharing E) {
    Bool? Test(E.Message mL, E.Message mR) {
        if (mL == mR) {
            return None;
        }
        return E.Reconstruct(E.Share(mL)) == mL;
    }
}

Game Right(SecretSharing E) {
    Bool? Test(E.Message mL, E.Message mR) {
        if (mL == mR) {
            return None;
        }
        return E.Reconstruct(E.Share(mR)) == mR;
    }
}

export as Security;
