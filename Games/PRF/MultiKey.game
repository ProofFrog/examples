import '../../Primitives/PRF.primitive';

Game Real(PRF F) {
    BitString<F.out> Lookup(BitString<F.in> x) {
        BitString<F.lambda> k <- BitString<F.lambda>;
        return F.evaluate(k, x);
    }
}

Game Random(PRF F) {
    BitString<F.out> Lookup(BitString<F.in> x) {
        BitString<F.out> r <- BitString<F.out>;
        return r;
    }
}

export as MultiKeyPRFSecurity;
