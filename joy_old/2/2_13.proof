// Simplified proof that DoubleOTP has INDOT$.
// The engine's uniform XOR simplification recognizes that
// k[0] + k[1] + m (with k[0], k[1] uniform) canonicalizes to uniform

import '../../joy_old/2/2_12_DoubleOTP.scheme';
import '../../Games/SymEnc/INDOT$.game';

proof:

let:
    Int lambda;
    DoubleOTP D = DoubleOTP(lambda);

assume:

theorem:
    INDOT$(D);

games:
    INDOT$(D).Real against INDOT$(D).Adversary;

    INDOT$(D).Random against INDOT$(D).Adversary;
