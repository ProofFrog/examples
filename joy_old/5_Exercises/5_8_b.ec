            ={glob G} ==> ={res, glob G} ].
  proof.
    transitivity Aug_micro_2_left_5(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply left_to_aug_micro_2_left_5 | apply aug_to_right_micro_2_left_5 ].
  qed.

