  (* transform: Symbolic Computation (bucket=canned) *)
  lemma micro_2_left_4 :
    equiv [ Step_2L_state_4(G).query ~ Step_2L_state_5(G).query :
            ={glob G} ==> ={res, glob G} ].
  proof.
    proc; sp; wp; sim.
  qed.

    module Mid_micro_2_left_5 (G : G_c.Scheme) = {
      proc query() : bs_2_lambda = {
        var challenger_Query_r0 : bs_3_lambda;
        var challenger_Query_r0_0, challenger_Query_r0_1 : bs_lambda;
        var _gap : bs_lambda;
        challenger_Query_r0_0 <$ dbs_lambda;
        challenger_Query_r0_1 <$ dbs_lambda;
        _gap <$ dbs_lambda;
        challenger_Query_r0 <- concat3_bs_lambda_bs_lambda_bs_lambda_to_bs_3_lambda challenger_Query_r0_0 challenger_Query_r0_1 _gap;
        return concat_bs_lambda_bs_lambda_to_bs_2_lambda
                 (slice_bs_3_lambda_to_bs_lambda challenger_Query_r0 0 lambda)
                 (slice_bs_3_lambda_to_bs_lambda challenger_Query_r0 lambda (2*lambda));
      }
    }.

    module Aug_micro_2_left_5 (G : G_c.Scheme) = {
      proc query() : bs_2_lambda = {
        var challenger_Query_r0_0, challenger_Query_r0_1 : bs_lambda;
        var _gap : bs_lambda;
        challenger_Query_r0_0 <$ dbs_lambda;
        challenger_Query_r0_1 <$ dbs_lambda;
        _gap <$ dbs_lambda;
        return concat_bs_lambda_bs_lambda_to_bs_2_lambda challenger_Query_r0_0 challenger_Query_r0_1;
      }
    }.

    lemma left_to_mid_micro_2_left_5 :
      equiv [ Step_2L_state_5(G).query ~ Mid_micro_2_left_5(G).query :
              ={glob G} ==> ={res, glob G} ].
    proof.
    proc.
    seq 1 4 : (={glob G} /\ challenger_Query_r0{1} = challenger_Query_r0{2}); last by auto.
    rndsem*{2} 0.
    conseq (: ={glob G} ==> ={glob G} /\ challenger_Query_r0{1} = challenger_Query_r0{2}) => //.
    rnd (fun (z : bs_3_lambda) => z) (fun (z : bs_3_lambda) => z); skip => />.
    rewrite -dbs_3_lambda_split3_bs_lambda_bs_lambda_bs_lambda /=; smt(dbs_3_lambda_split3_bs_lambda_bs_lambda_bs_lambda).
    qed.

    lemma mid_to_aug_micro_2_left_5 :
      equiv [ Mid_micro_2_left_5(G).query ~ Aug_micro_2_left_5(G).query :
              ={glob G} ==> ={res, glob G} ].
    proof.
    proc; wp; rnd; rnd; rnd; skip => /> *; smt(slice_concat3_p1_bs_lambda_bs_lambda_bs_lambda_bs_3_lambda slice_concat3_p2_bs_lambda_bs_lambda_bs_lambda_bs_3_lambda).
    qed.

    lemma aug_to_right_micro_2_left_5 :
      equiv [ Aug_micro_2_left_5(G).query ~ Step_2L_state_6(G).query :
              ={glob G} ==> ={res, glob G} ].
    proof.
    proc.
    seq 2 2 : (={glob G} /\ challenger_Query_r0_0{1} = challenger_Query_r0_0{2} /\ challenger_Query_r0_1{1} = challenger_Query_r0_1{2}).
    by auto.
    rnd{1}.
    by auto; smt(dbs_lambda_ll).
    qed.

    lemma left_to_aug_micro_2_left_5 :
      equiv [ Step_2L_state_5(G).query ~ Aug_micro_2_left_5(G).query :
              ={glob G} ==> ={res, glob G} ].
    proof.
    transitivity Mid_micro_2_left_5(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply left_to_mid_micro_2_left_5 | apply mid_to_aug_micro_2_left_5 ].
    qed.

