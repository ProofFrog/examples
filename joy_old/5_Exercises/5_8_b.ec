  (* transform: Merge Uniform Samples (bucket=canned) *)
  lemma micro_2_left_8 :
    equiv [ Step_2L_state_8(G).query ~ Step_2L_state_9(G).query :
            ={glob G} ==> ={res, glob G} ].
  proof.
    proc.
    transitivity {2}
      { challenger_Query_r0_0 <$ dmap (dbs_lambda `*` dbs_lambda)
                              (fun (p : bs_lambda * bs_lambda) =>
                                 concat_bs_lambda_bs_lambda_to_bs_2_lambda p.`1 p.`2); }
      (={glob G} ==>
       ={glob G} /\ concat_bs_lambda_bs_lambda_to_bs_2_lambda challenger_Query_r0_0{1} challenger_Query_r0_1{1} = challenger_Query_r0_0{2})
      (={glob G} ==> ={glob G} /\ ={challenger_Query_r0_0}).
    - by smt().
    - by smt().
    - seq 2 1 : (={glob G} /\
                 challenger_Query_r0_0{2} = concat_bs_lambda_bs_lambda_to_bs_2_lambda challenger_Query_r0_0{1} challenger_Query_r0_1{1}); last by auto.
      rndsem*{1} 0.
      rnd (fun (p : bs_lambda * bs_lambda) => concat_bs_lambda_bs_lambda_to_bs_2_lambda p.`1 p.`2)
          (fun (z : bs_2_lambda) =>
             (slice_bs_2_lambda_to_bs_lambda z 0 lambda,
              slice_bs_2_lambda_to_bs_lambda z lambda (2*lambda))).
      skip => />.
      split; first by smt(concat_slices_id_bs_lambda_bs_lambda_bs_2_lambda).
      move => _.
      split.
      + move => xR HxR.
        rewrite dmap1E /(\o) /pred1 /=.
        rewrite -(dmap_dprodE dbs_lambda dbs_lambda
                              (fun p : bs_lambda * bs_lambda => p)) dmap_id.
        apply mu_eq => p /=.
        smt(concat_slices_id_bs_lambda_bs_lambda_bs_2_lambda slice_concat_left_bs_lambda_bs_lambda_bs_2_lambda slice_concat_right_bs_lambda_bs_lambda_bs_2_lambda).
      + move => _ p Hp; split.
        * smt(supp_dmap supp_dprod dprod_dlet dmap_dprodE dmap_id).
        * by smt(slice_concat_left_bs_lambda_bs_lambda_bs_2_lambda slice_concat_right_bs_lambda_bs_lambda_bs_2_lambda).
    - rnd (fun (z : bs_2_lambda) => z) (fun (z : bs_2_lambda) => z).
      skip => />.
      smt(dbs_2_lambda_split_bs_lambda_bs_lambda).
  qed.

