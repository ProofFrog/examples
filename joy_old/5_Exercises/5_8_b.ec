  lemma hop_0_chain :
    equiv [ Step_0L_state_0(G).query ~ Step_0R_state_0(G).query :
            ={glob G} ==> ={res, glob G} ].
  proof.
    (* Chain through per-transform micro-lemmas. *)
    transitivity Step_0L_state_1(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_0_left_0 |].
    transitivity Step_0L_state_2(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_0_left_1 |].
    transitivity Step_0L_state_3(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_0_left_2 |].
    transitivity Step_0L_state_4(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_0_left_3 |].
    transitivity Step_0L_state_5(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_0_left_4 |].
    transitivity Step_0L_state_6(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_0_left_5 |].
    transitivity Step_0R_state_6(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply canon_bridge_0 |].
    transitivity Step_0R_state_5(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_0_right_5_rev |].
    transitivity Step_0R_state_4(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_0_right_4_rev |].
    transitivity Step_0R_state_3(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_0_right_3_rev |].
    transitivity Step_0R_state_2(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_0_right_2_rev |].
    transitivity Step_0R_state_1(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_0_right_1_rev |].
    apply micro_0_right_0_rev.
  qed.

  module Step_2L_state_0 (G : G_c.Scheme) = {
    proc query() : bs_2_lambda = {
      var challenger_Query_r0 : bs_3_lambda;
      var result : bs_3_lambda;
      var x : bs_lambda;
      var y : bs_lambda;
      challenger_Query_r0 <$ dbs_3_lambda;
      result <- challenger_Query_r0;
      x <- slice_bs_3_lambda_to_bs_lambda result 0 lambda;
      y <- slice_bs_3_lambda_to_bs_lambda result lambda (2*lambda);
      return concat_bs_lambda_bs_lambda_to_bs_2_lambda x y;
    }
  }.

