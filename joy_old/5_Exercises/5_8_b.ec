    equiv [ Step_2R_state_4(G).query ~ Step_2R_state_3(G).query :
            ={glob G} ==> ={res, glob G} ].
  proof.
    proc; sp; wp; sim.
  qed.

  (* transform: Variable Standardization (bucket=canned) *)
  lemma micro_2_right_4_fwd :
    equiv [ Step_2R_state_4(G).query ~ Step_2R_state_5(G).query :
            ={glob G} ==> ={res, glob G} ].
  proof.
    proc; sp; wp; sim.
  qed.

  (* transform: Variable Standardization (reversed) (bucket=canned) *)
  lemma micro_2_right_4_rev :
    equiv [ Step_2R_state_5(G).query ~ Step_2R_state_4(G).query :
            ={glob G} ==> ={res, glob G} ].
  proof.
    proc; sp; wp; sim.
  qed.

  lemma canon_bridge_2 :
    equiv [ Step_2L_state_13(G).query ~ Step_2R_state_5(G).query :
            ={glob G} ==> ={res, glob G} ].
  proof.
    proc; sim.
  qed.

  lemma hop_2_chain :
    equiv [ Step_2L_state_0(G).query ~ Step_2R_state_0(G).query :
            ={glob G} ==> ={res, glob G} ].
  proof.
    (* Chain through per-transform micro-lemmas. *)
    transitivity Step_2L_state_1(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_left_0 |].
    transitivity Step_2L_state_2(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_left_1 |].
    transitivity Step_2L_state_3(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_left_2 |].
    transitivity Step_2L_state_4(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_left_3 |].
    transitivity Step_2L_state_5(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_left_4 |].
    transitivity Step_2L_state_6(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_left_5 |].
    transitivity Step_2L_state_7(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_left_6 |].
    transitivity Step_2L_state_8(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_left_7 |].
    transitivity Step_2L_state_9(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_left_8 |].
    transitivity Step_2L_state_10(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_left_9 |].
    transitivity Step_2L_state_11(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_left_10 |].
    transitivity Step_2L_state_12(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_left_11 |].
    transitivity Step_2L_state_13(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_left_12 |].
    transitivity Step_2R_state_5(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply canon_bridge_2 |].
    transitivity Step_2R_state_4(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_right_4_rev |].
    transitivity Step_2R_state_3(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_right_3_rev |].
    transitivity Step_2R_state_2(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_right_2_rev |].
    transitivity Step_2R_state_1(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply micro_2_right_1_rev |].
    apply micro_2_right_0_rev.
  qed.

  (* ===== Per-hop equivalence lemmas ===== *)

  lemma hop_0 :
    equiv [ H_c.PRGSecurity_Real(PRG_5_8_b(G)).query ~ R1(G, PRG_5_8_b(G), G_c.PRGSecurity_Real(G)).query :
            ={glob G} ==> ={res, glob G} ].
  proof.
    (* Per-transform: bridge wrappers to flat states, chain through. *)
    transitivity Step_0L_state_0(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | proc; inline *; sp; wp; sim |].
    transitivity Step_0R_state_0(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply hop_0_chain | proc; inline *; sp; wp; sim ].
    qed.

  lemma hop_2 :
    equiv [ R1(G, PRG_5_8_b(G), G_c.PRGSecurity_Random(G)).query ~ H_c.PRGSecurity_Random(PRG_5_8_b(G)).query :
            ={glob G} ==> ={res, glob G} ].
  proof.
    (* Per-transform: bridge wrappers to flat states, chain through. *)
    transitivity Step_2L_state_0(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | proc; inline *; sp; wp; sim |].
    transitivity Step_2R_state_0(G).query (={glob G} ==> ={res, glob G}) (={glob G} ==> ={res, glob G}); [ smt() | smt() | apply hop_2_chain | proc; inline *; sp; wp; sim ].
    qed.

  (* ===== Per-hop probability lemmas ===== *)

  (* Hop 0: interchangeability. The two adjacent games are equivalent (no advantage). *)

  lemma hop_0_pr (A <: H_c.PRGSecurity_Adv {-G}) &m :
    Pr[Game_step_0(G, A).main() @ &m : res] = Pr[Game_step_1(G, A).main() @ &m : res].
  proof.
    byequiv (_: ={glob A, glob G} ==> ={res}) => //; proc.
    call (_: ={glob G}); first by conseq hop_0.
    auto.
    qed.

  (* Hop 1: assumption hop. Bounded by the PRGSecurity_advantage axiom applied to R1_Adv. *)

  lemma hop_1_pr (A <: H_c.PRGSecurity_Adv {-G}) &m :
    `| Pr[Game_step_1(G, A).main() @ &m : res] - Pr[Game_step_2(G, A).main() @ &m : res] | <= G_c.eps_PRGSecurity.
  proof.
    have hL : Pr[Game_step_1(G, A).main() @ &m : res]
            = Pr[G_c.Game_PRGSecurity_Real(G, R1_Adv(G, A)).main() @ &m : res]
      by byequiv => //; proc; inline *; sim.
    have hR : Pr[Game_step_2(G, A).main() @ &m : res]
            = Pr[G_c.Game_PRGSecurity_Random(G, R1_Adv(G, A)).main() @ &m : res]
      by byequiv => //; proc; inline *; sim.
    rewrite hL hR.
    apply (G_c.PRGSecurity_advantage G (R1_Adv(G, A)) &m).
    qed.

  (* Hop 2: interchangeability. The two adjacent games are equivalent (no advantage). *)

  lemma hop_2_pr (A <: H_c.PRGSecurity_Adv {-G}) &m :
    Pr[Game_step_2(G, A).main() @ &m : res] = Pr[Game_step_3(G, A).main() @ &m : res].
  proof.
    byequiv (_: ={glob A, glob G} ==> ={res}) => //; proc.
    call (_: ={glob G}); first by conseq hop_2.
    auto.
    qed.

  (* ===== Main theorem ===== *)

  lemma main_theorem (A <: H_c.PRGSecurity_Adv {-G}) &m :
    `| Pr[Game_step_0(G, A).main() @ &m : res] - Pr[Game_step_3(G, A).main() @ &m : res] | <= G_c.eps_PRGSecurity.
  proof.
    have h0 := hop_0_pr A &m.
    have h1 := hop_1_pr A &m.
    have h2 := hop_2_pr A &m.
    smt(G_c.eps_PRGSecurity_pos).
    qed.
end section Main.
